import { webview } from '@kit.ArkWeb';

@Builder
export function aiChatBuilder() {
  AiChatComponent();
}

@Component
export struct AiChatComponent {
  private webController: webview.WebviewController = new webview.WebviewController();

  build() {
    NavDestination() {
      Web({ src: 'http://172.24.36.58:3000', controller: this.webController })
        .width('100%')
        .height('100%')
    }
    .title('AI Chat')
  }
}
